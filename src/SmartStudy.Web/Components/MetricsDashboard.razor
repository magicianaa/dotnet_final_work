@using SmartStudy.Core

<section class="metrics-grid">
    <div class="metric">
        <span>LLM</span>
        <strong>@(State?.LlmModel ?? "loading")</strong>
        <small>@(State?.LlmProfile ?? "-") · @(State?.LlmApiKeyConfigured == true ? "key ready" : "missing key")</small>
    </div>
    <div class="metric">
        <span>Project</span>
        <strong>@(State?.ProjectName ?? "loading")</strong>
        <small>@(State?.ConversationTitle ?? "-")</small>
    </div>
    <div class="metric">
        <span>Embedding</span>
        <strong>@(State?.EmbeddingProvider ?? "loading")</strong>
        <small>@(State?.EmbeddingModel ?? "-")</small>
    </div>
    <div class="metric">
        <span>Knowledge</span>
        <strong>@(State?.LoadedChunkCount.ToString() ?? "0") chunks</strong>
        <small>@(State?.KnowledgeFileCount.ToString() ?? "0") markdown · @(State?.ImportedMaterialCount.ToString() ?? "0") imported</small>
    </div>
</section>

@code {
    [Parameter]
    public DashboardState? State { get; set; }
}
