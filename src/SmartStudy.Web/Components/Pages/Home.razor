@page "/"
@rendermode InteractiveServer
@inject ReActAgent Agent
@inject PlanExecuteAgent PlanExecute
@inject KnowledgeIndexer Indexer
@inject CourseMaterialImporter Importer
@inject DashboardStateService Dashboard
@inject WebAgentTraceStore TraceStore
@inject WebChatCommandService Commands
@inject LearningProjectService Projects
@inject IConversationMemory Memory
@implements IDisposable

<PageTitle>SmartStudy Agent</PageTitle>

<section class="workspace">
    <header class="workspace-header">
        <div>
            <p class="eyebrow">SmartStudy Web</p>
            <h1>智能学习助手工作台</h1>
        </div>
        <div class="header-actions">
            <button class="icon-button" title="刷新状态" @onclick="LoadDashboardAsync">↻</button>
            <button class="primary-button" @onclick="BuildIndexAsync" disabled="@isBusy">重建索引</button>
        </div>
    </header>

    @if (!string.IsNullOrWhiteSpace(statusMessage))
    {
        <div class="status-line">@statusMessage</div>
    }

    <MetricsDashboard State="state" />

    <section class="main-grid">
        <ProjectSidebar Workspace="workspaceState"
                        @bind-ProjectDirectory="newProjectDirectory"
                        @bind-ProjectName="newProjectName"
                        Message="@projectMessage"
                        IsBusy="isBusy"
                        OnCreateProject="CreateProjectAsync"
                        OnSelectProject="SelectProjectAsync"
                        OnDeleteProject="DeleteProjectAsync"
                        OnCreateConversation="CreateConversationAsync"
                        OnSelectConversation="SelectConversationAsync"
                        OnDeleteConversation="DeleteConversationAsync"
                        OnRefresh="LoadWorkspaceAsync" />

        <div class="conversation-panel">
            @if (isPlanMode)
            {
                <div class="plan-mode-panel">
                    <PlanExecutePanel @bind-PlanGoal="planGoal"
                                      IsBusy="isBusy"
                                      OnRun="RunPlanExecuteAsync"
                                      PlanResult="planResult" />
                </div>
            }

            <ChatPanel Messages="messages" 
                       QuickPrompts="quickPrompts" 
                       CommandHints="commandHints" 
                       IsBusy="isBusy" 
                       @bind-UseStreaming="useStreaming" 
                       @bind-Question="question" 
                       OnAsk="AskAsync" 
                       OnClearChat="ClearChat"
                       IsPlanMode="isPlanMode"
                       OnTogglePlanMode="TogglePlanMode"
                       OnShowImportModal="() => showImportModal = true" />
        </div>

        <aside class="inspector">
            <TimelineInspector TimelineItems="TimelineItems"
                               CommandHints="commandHints"
                               State="state" />
        </aside>
    </section>
</section>

<ImportModal IsVisible="showImportModal" 
             OnClose="() => showImportModal = false" 
             OnImportComplete="LoadDashboardAsync" />

@code {
    private DashboardState? state;
    private LearningWorkspaceState? workspaceState;
    private string question = "";
    private string planGoal = "解释 ReAct Agent";
    private string statusMessage = "";
    private string projectMessage = "";
    private string newProjectDirectory = "";
    private string newProjectName = "";
    private bool isBusy;
    private bool useStreaming = true;
    private bool isPlanMode = false;
    private bool showImportModal = false;
    private PlanExecuteResult? planResult;
    private readonly List<ChatUiMessage> messages = new();
    private IReadOnlyList<TimelineItem> TimelineItems => BuildTimelineItems(TraceStore.Events);

    private readonly QuickPrompt[] quickPrompts =
    [
        new("解释 ReAct", "请检索课程资料，并解释 ReAct Agent 的 Thought、Action、Observation 工作流。"),
        new("生成计划", "我对 ReAct 和 MCP 比较薄弱，目标是完成期末答辩，请更新我的学习画像并制定 3 天复习计划。"),
        new("出练习题", "请基于课程资料生成 3 道关于 Agent Loop 的选择题。"),
        new("查看进度", "请查看我的学习进度和最近完成记录。"),
        new("错题复盘", "请列出我的错题，并按主题总结薄弱点。")
    ];
    private readonly CommandHint[] commandHints =
    [
        new(":reset", "清空对话记忆", ":reset"),
        new(":models", "查看模型列表", ":models"),
        new(":multi <goal>", "启动 Multi-Agent 协作", ":multi 帮我准备 Agent 项目答辩"),
        new(":plan-execute <goal>", "启动 Plan-and-Execute", ":plan-execute 解释 ReAct Agent，并展示质量检查结果"),
        new(":search <query>", "调用 knowledge_search", ":search ReAct Agent 的工作流"),
        new(":profile", "查看学习画像", ":profile"),
        new(":plan <goal>", "调用 study_plan", ":plan 制定一个 3 天期末答辩复习计划"),
        new(":progress", "调用 show_progress", ":progress"),
        new(":quiz <material> | <count>", "调用 make_quiz", ":quiz Agent Loop | 3"),
        new(":answer <quizId> | <number> | <answer> | <topic>", "调用 submit_quiz_answer；也可直接回复第1题选A", ":answer latest | 1 | A | Agent Loop"),
        new(":mistakes [topic]", "调用 show_mistakes", ":mistakes"),
        new(":calc <expression>", "调用 calculate", ":calc (45+15)/6"),
        new(":import <path> | <glob>", "调用 import_course_materials", ":import C:\\Users\\21125\\Desktop\\SEM & SEP\\ppts")
    ];

    protected override async Task OnInitializedAsync()
    {
        TraceStore.Changed += HandleTraceChanged;
        Projects.Changed += HandleProjectChanged;
        await LoadWorkspaceAsync();
        await LoadDashboardAsync();
        RestoreMessagesFromMemory();
    }

    private void TogglePlanMode()
    {
        isPlanMode = !isPlanMode;
    }

    private async Task LoadDashboardAsync()
    {
        state = await Dashboard.GetAsync();
    }

    private async Task LoadWorkspaceAsync()
    {
        workspaceState = await Projects.GetStateAsync();
    }

    private async Task BuildIndexAsync()
    {
        isBusy = true;
        statusMessage = "正在重建知识库索引...";
        try
        {
            await Indexer.BuildAsync();
            statusMessage = "知识库索引已重建。";
            projectMessage = $"已重建 {Projects.CurrentProject.Name} 的项目索引。";
            await LoadDashboardAsync();
        }
        catch (Exception ex)
        {
            statusMessage = $"索引构建失败：{ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task AskAsync()
    {
        var input = question.Trim();
        if (input.Length == 0 || isBusy) return;

        isBusy = true;
        statusMessage = "Agent 正在处理...";
        TraceStore.Clear();
        messages.Add(new ChatUiMessage("user", "你", input));
        question = "";

        try
        {
            var commandResult = await Commands.TryExecuteAsync(input, useStreaming);
            if (commandResult.Handled)
            {
                messages.Add(new ChatUiMessage("agent", "SmartStudy", commandResult.Response));
                statusMessage = commandResult.StatusMessage;
                if (commandResult.UseStreaming.HasValue)
                {
                    useStreaming = commandResult.UseStreaming.Value;
                }
                if (commandResult.RefreshDashboard)
                {
                    await LoadDashboardAsync();
                }
            }
            else if (useStreaming)
            {
                await AskStreamingAsync(input);
            }
            else
            {
                var result = await Agent.RunAsync(input);
                messages.Add(new ChatUiMessage("agent", "SmartStudy", result.FinalAnswer));
                statusMessage = result.ReachedLimit ? "已达到最大推理步数。" : $"完成，共 {result.Steps} 步。";
            }
            await LoadDashboardAsync();
            await Projects.TouchConversationAsync(input);
            await LoadWorkspaceAsync();
        }
        catch (Exception ex)
        {
            messages.Add(new ChatUiMessage("agent error", "SmartStudy", $"出错：{ex.Message}"));
            statusMessage = "Agent 调用失败。";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task RunPlanExecuteAsync()
    {
        if (isBusy || string.IsNullOrWhiteSpace(planGoal)) return;

        isBusy = true;
        statusMessage = "正在运行 Plan-and-Execute...";
        planResult = null;
        try
        {
            await Indexer.LoadIfExistsAsync();
            planResult = await PlanExecute.RunAsync(planGoal);
            statusMessage = planResult.Review.Passed
                ? "Plan-and-Execute 完成，质量检查通过。"
                : "Plan-and-Execute 完成，质量检查有待处理项。";
            await LoadDashboardAsync();
        }
        catch (Exception ex)
        {
            statusMessage = $"Plan-and-Execute 失败：{ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task AskStreamingAsync(string input)
    {
        var agentIndex = messages.Count;
        messages.Add(new ChatUiMessage("agent streaming", "SmartStudy", ""));
        var finalSteps = 0;
        var reachedLimit = false;

        await foreach (var ev in Agent.RunStreamingAsync(input))
        {
            TraceStore.Add(ev);
            finalSteps = Math.Max(finalSteps, ev.Step);
            switch (ev.Type)
            {
                case AgentEventType.StreamDelta:
                    AppendToAgentMessage(agentIndex, ev.Content ?? "");
                    await InvokeAsync(StateHasChanged);
                    break;
                case AgentEventType.FinalAnswer:
                    UpdateAgentMessage(agentIndex, string.IsNullOrWhiteSpace(ev.Content)
                        ? messages[agentIndex].Content
                        : ev.Content);
                    await InvokeAsync(StateHasChanged);
                    break;
                case AgentEventType.Error:
                    reachedLimit = string.Equals(ev.Content, "达到最大循环步数", StringComparison.OrdinalIgnoreCase);
                    if (string.IsNullOrWhiteSpace(messages[agentIndex].Content))
                        UpdateAgentMessage(agentIndex, ev.Content ?? "Agent 运行出错。");
                    break;
            }
        }

        if (string.IsNullOrWhiteSpace(messages[agentIndex].Content))
            UpdateAgentMessage(agentIndex, "Agent 没有返回文本内容，请查看右侧时间线中的工具调用结果。");

        statusMessage = reachedLimit ? "已达到最大推理步数。" : $"流式输出完成，共 {finalSteps} 步。";
        if (!string.IsNullOrWhiteSpace(messages[agentIndex].Content)
            && !messages[agentIndex].Role.Contains("error", StringComparison.OrdinalIgnoreCase))
        {
            UpdateAgentMessage(agentIndex, messages[agentIndex].Content);
        }
    }

    private void AppendToAgentMessage(int index, string delta)
    {
        if (index < 0 || index >= messages.Count || delta.Length == 0) return;
        var current = messages[index];
        messages[index] = current with
        {
            Role = "agent streaming",
            Content = current.Content + delta
        };
    }

    private void UpdateAgentMessage(int index, string content)
    {
        if (index < 0 || index >= messages.Count) return;
        var current = messages[index];
        messages[index] = current with
        {
            Role = current.Role.Contains("error", StringComparison.OrdinalIgnoreCase) ? current.Role : "agent",
            Content = content
        };
    }

    private void ClearChat()
    {
        messages.Clear();
        Memory.Reset();
        TraceStore.Clear();
        statusMessage = "";
    }

    private async Task CreateProjectAsync()
    {
        if (isBusy || string.IsNullOrWhiteSpace(newProjectDirectory)) return;

        isBusy = true;
        projectMessage = "正在创建学习项目并导入资料...";
        try
        {
            var project = await Projects.CreateProjectAsync(newProjectDirectory, newProjectName);
            var result = await Importer.ImportAsync(newProjectDirectory);
            projectMessage = $"项目 {project.Name} 已创建，导入 {result.FilesRead} 个文件，索引 {result.ChunksIndexed} 个片段。";
            newProjectDirectory = "";
            newProjectName = "";
            ResetConversationUi();
            await LoadWorkspaceAsync();
            await LoadDashboardAsync();
        }
        catch (Exception ex)
        {
            projectMessage = $"创建项目失败：{ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task SelectProjectAsync(string projectId)
    {
        if (isBusy) return;
        await Projects.SelectProjectAsync(projectId);
        Memory.Reload();
        ResetConversationUi();
        RestoreMessagesFromMemory();
        await LoadWorkspaceAsync();
        await LoadDashboardAsync();
        projectMessage = $"已切换到项目：{Projects.CurrentProject.Name}";
    }

    private async Task CreateConversationAsync()
    {
        if (isBusy) return;
        await Projects.CreateConversationAsync();
        Memory.Reload();
        ResetConversationUi();
        RestoreMessagesFromMemory();
        await LoadWorkspaceAsync();
        await LoadDashboardAsync();
        projectMessage = $"已新建对话：{Projects.CurrentConversation.Title}";
    }

    private async Task SelectConversationAsync(string conversationId)
    {
        if (isBusy) return;
        await Projects.SelectConversationAsync(conversationId);
        Memory.Reload();
        ResetConversationUi();
        RestoreMessagesFromMemory();
        await LoadWorkspaceAsync();
        await LoadDashboardAsync();
        projectMessage = $"已切换到对话：{Projects.CurrentConversation.Title}";
    }

    private async Task DeleteProjectAsync(string projectId)
    {
        if (isBusy) return;

        isBusy = true;
        try
        {
            var deleted = await Projects.DeleteProjectAsync(projectId);
            Memory.Reload();
            ResetConversationUi();
            RestoreMessagesFromMemory();
            await LoadWorkspaceAsync();
            await LoadDashboardAsync();
            projectMessage = $"已删除项目：{deleted.Name}";
        }
        catch (Exception ex)
        {
            projectMessage = $"删除项目失败：{ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task DeleteConversationAsync(string conversationId)
    {
        if (isBusy) return;

        isBusy = true;
        try
        {
            var deleted = await Projects.DeleteConversationAsync(conversationId);
            Memory.Reload();
            ResetConversationUi();
            RestoreMessagesFromMemory();
            await LoadWorkspaceAsync();
            await LoadDashboardAsync();
            projectMessage = $"已删除对话：{deleted.Title}";
        }
        catch (Exception ex)
        {
            projectMessage = $"删除对话失败：{ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private void HandleTraceChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void HandleProjectChanged()
    {
        _ = InvokeAsync(async () =>
        {
            await LoadWorkspaceAsync();
            await LoadDashboardAsync();
            StateHasChanged();
        });
    }

    private void ResetConversationUi()
    {
        messages.Clear();
        TraceStore.Clear();
        statusMessage = "";
    }

    private void RestoreMessagesFromMemory()
    {
        messages.Clear();
        foreach (var msg in Memory.Messages.Where(m => m.Role is ChatRoles.User or ChatRoles.Assistant))
        {
            if (string.IsNullOrWhiteSpace(msg.Content)) continue;
            messages.Add(msg.Role == ChatRoles.User
                ? new ChatUiMessage("user", "你", msg.Content)
                : new ChatUiMessage("agent", "SmartStudy", msg.Content));
        }
    }

    private static IReadOnlyList<TimelineItem> BuildTimelineItems(IReadOnlyList<AgentEvent> events)
    {
        var items = new List<TimelineItem>();
        var stream = new System.Text.StringBuilder();
        int? streamStep = null;

        foreach (var ev in events)
        {
            if (ev.Type == AgentEventType.StreamDelta)
            {
                streamStep ??= ev.Step;
                if (streamStep == ev.Step)
                {
                    stream.Append(ev.Content);
                    continue;
                }

                FlushStream(items, streamStep.Value, stream);
                streamStep = ev.Step;
                stream.Append(ev.Content);
                continue;
            }

            if (streamStep.HasValue)
            {
                FlushStream(items, streamStep.Value, stream);
                streamStep = null;
            }

            items.Add(new TimelineItem(
                ev.Step,
                ev.Type.ToString(),
                ev.Type.ToString().ToLowerInvariant(),
                ev.ToolName,
                ev.Content,
                ev.Type == AgentEventType.Observation ? 520 : 300));
        }

        if (streamStep.HasValue)
            FlushStream(items, streamStep.Value, stream);

        return items;
    }

    private static void FlushStream(List<TimelineItem> items, int step, System.Text.StringBuilder stream)
    {
        if (stream.Length == 0) return;
        items.Add(new TimelineItem(step, "Streaming Answer", "streaming-answer", null, stream.ToString(), 520));
        stream.Clear();
    }

    public void Dispose()
    {
        TraceStore.Changed -= HandleTraceChanged;
        Projects.Changed -= HandleProjectChanged;
    }
}
